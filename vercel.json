{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/midiboi/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/midiboi/songs/:path*",
      "destination": "/songs/:path*"
    },
    {
      "source": "/midiboi/favicon.svg",
      "destination": "/favicon.svg"
    },
    {
      "source": "/midiboi",
      "destination": "/index.html"
    },
    {
      "source": "/midiboi/",
      "destination": "/index.html"
    },
    {
      "source": "/midiboi/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
